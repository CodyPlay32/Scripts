-- Variables de control
local isActive = true
local checkInterval = 3

-- Función para verificar si es administrador
local function isAdmin(playerName)
    for _, adminName in ipairs(admins) do
        if adminName == playerName then
            return true
        end
    end
    return false
end

-- Función para auto-expulsarse (desconectarse del servidor)
local function selfKick()
    game.Players.LocalPlayer:Kick("Administrador detectado - Auto-expulsión activada")
end

-- Verificar si hay administradores en el servidor
local function checkForAdmins()
    if not isActive then return end
    
    for _, player in ipairs(game.Players:GetPlayers()) do
        if isAdmin(player.Name) then
            Status.Text = "Admin: " .. player.Name
            Status.TextColor3 = Color3.fromRGB(255, 85, 85)
            
            -- Esperar un momento antes de auto-expulsarse
            wait(1)
            
            -- Auto-expulsarse
            selfKick()
            return
        end
    end
end

-- Comprobar cuando un jugador se une
game.Players.PlayerAdded:Connect(function(player)
    if not isActive then return end
    
    if isAdmin(player.Name) then
        Status.Text = "Admin: " .. player.Name
        Status.TextColor3 = Color3.fromRGB(255, 85, 85)
        
        -- Esperar un momento antes de auto-expulsarse
        wait(1)
        
        -- Auto-expulsarse
        selfKick()
    end
end)

-- Botón de activar/desactivar
ToggleButton.MouseButton1Click:Connect(function()
    isActive = not isActive
    if isActive then
        ToggleButton.Text = "Desactivar"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(85, 170, 255)
        Status.Text = "Estado: Activo"
        Status.TextColor3 = Color3.fromRGB(85, 255, 85)
    else
        ToggleButton.Text = "Activar"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 85, 85)
        Status.Text = "Estado: Inactivo"
        Status.TextColor3 = Color3.fromRGB(255, 85, 85)
    end
end)

-- Comprobación periódica
spawn(function()
    while wait(checkInterval) do
        checkForAdmins()
    end
end)

